/**
 * @param {Function} fn
 * @param {number} t milliseconds
 * @return {Function}
 */
var debounce = function(fn, t) {
    let timeoutId;
    
    return function(...args) {
        // Cancel the previous pending execution
        clearTimeout(timeoutId);
        
        // Schedule the new execution after t milliseconds
        timeoutId = setTimeout(() => {
            fn(...args);
        }, t);
    };
};
