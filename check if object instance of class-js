/**
 * @param {any} obj
 * @param {any} classFunction
 * @return {boolean}
 */
var checkIfInstanceOf = function(obj, classFunction) {
    // 1. If obj is null or undefined, it can't have a prototype chain
    // 2. If classFunction is not a function/class, it can't be a constructor
    if (obj === null || obj === undefined || typeof classFunction !== 'function') {
        return false;
    }

    // Get the prototype of the object (handles primitives via auto-boxing)
    let currPrototype = Object.getPrototypeOf(obj);

    while (currPrototype !== null) {
        // If we find the class's prototype in the chain, return true
        if (currPrototype === classFunction.prototype) {
            return true;
        }
        // Move up to the next prototype in the chain
        currPrototype = Object.getPrototypeOf(currPrototype);
    }

    return false;
};
