/**
 * @param {number} n
 * @return {Function} counter
 */
var createCounter = function(n) {
    // This variable 'n' is preserved in the closure
    return function() {
        return n++; 
    };
};

/** 
 * const counter = createCounter(10)
 * counter() // 10
 * counter() // 11
 * counter() // 12
 */
