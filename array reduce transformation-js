/**
 * @param {number[]} nums
 * @param {Function} fn
 * @param {number} init
 * @return {number}
 */
var reduce = function(nums, fn, init) {
    let val = init;
    
    // Iterate through each element in the array
    for (let i = 0; i < nums.length; i++) {
        // Update val by applying the reducer function
        val = fn(val, nums[i]);
    }
    
    return val;
};
